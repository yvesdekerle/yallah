# Copy this file to `.env` and fill in your secrets.
# `.env` is gitignored — it never leaves your machine.

# Pexels API key — used by `npm run fetch:photos` to backfill activity photos.
# Sign up free at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# Google OAuth Web Client ID — enables the "Se connecter avec Google" button on
# the welcome screen (client-side SSO, no backend). Create one in Google Cloud
# Console → APIs & Services → Credentials → OAuth client ID (Web application),
# with authorized JS origins http://localhost:5173 + your Vercel domain.
# Put the real value in .env.local (gitignored) and in Vercel env vars. When
# unset, the Google button is disabled and only the demo flow is available.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
