# Copy this file to `.env` and fill in your secrets.
# `.env` is gitignored — it never leaves your machine.

# Pexels API key — used by `npm run fetch:photos` to backfill activity photos.
# Sign up free at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# Firebase web config — enables Google sign-in (Firebase Auth, Google provider)
# + Firestore (votes, profiles, per-user app version). Create a project at
# https://console.firebase.google.com, add a Web app, enable the Google sign-in
# provider (Authentication → Sign-in method), and create a Firestore database.
# Copy the web config values below. Put the real values in .env.local
# (gitignored) and in Vercel env vars. When unset, Google sign-in is disabled
# and only the demo flow is available (the app runs fully offline/local).
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# Seed script only (scripts/seed-firestore.ts): path to a Firebase service
# account JSON (Project settings → Service accounts → Generate new private key).
# Used by `npm run seed:firestore` to push the curated activities into Firestore.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
